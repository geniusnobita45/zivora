# Persistent production lead storage. Required in production unless Upstash-only rate limiting is paired with another durable lead database.
DATABASE_URL=

# Admin authentication. Generate with: node scripts/generate-admin-password-hash.mjs
ADMIN_PASSWORD_HASH=

# At least 32 random bytes. Used to sign admin sessions.
SESSION_SECRET=

# At least 32 random bytes. Used to hash rate-limit keys without storing raw IPs.
RATE_LIMIT_SECRET=

# Optional explicit same-origin allowlist additions, comma-separated. Production always allows https://zivoraai.co.in.
ALLOWED_ORIGINS=

# Optional durable Redis rate limiter. If omitted, DATABASE_URL is used for production rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
